# Dakota sandbox API key — get one at https://dakota.xyz/agentic-build → sandbox dashboard → API Keys.
# Never expose this to the browser (no NEXT_PUBLIC_ prefix).
DAKOTA_API_KEY=your_sandbox_api_key

# iron-session cookie secret (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_32_plus_char_random_string

# Database for the guild <-> customer mapping + ledger.
#
# Local dev: leave the Turso vars unset — the app uses a local libSQL/SQLite file:
DATABASE_PATH=./guildpay.db
#
# Serverless (e.g. Vercel): set these to a hosted Turso database and DATABASE_PATH is ignored.
# Create one with the Turso CLI:  turso db create guildpay  &&  turso db show guildpay --url  &&  turso db tokens create guildpay
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token
